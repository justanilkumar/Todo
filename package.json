{
  "name": "taskflow-cloud-todo",
  "version": "1.0.0",
  "description": "Cloud-Enabled Todo App with AWS S3 attachments and MongoDB Atlas integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "build": "npm --prefix frontend install && npm --prefix frontend run build",
    "install-all": "npm install && npm --prefix frontend install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.554.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.3.1",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
